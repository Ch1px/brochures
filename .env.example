# ============================================================
# Sanity (CMS + image CDN)
# Create project at https://www.sanity.io/manage
# ============================================================
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# API token with write access — used for server-side writes from the builder.
# Create under Sanity project → API → Tokens → Add → Editor role.
SANITY_API_WRITE_TOKEN=
# Webhook secret for ISR revalidation on publish.
# Set this when you create the Sanity webhook → /api/revalidate
SANITY_REVALIDATE_SECRET=

# ============================================================
# Clerk (auth for /admin and /studio)
# Create app at https://dashboard.clerk.com
# ============================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Comma-separated emails allowed into /admin and /studio.
# Keep tight — only add trusted admin emails.
ADMIN_EMAIL_ALLOWLIST=daniel@grandprixgrandtours.com,simon@grandprixgrandtours.com,jay@grandprixgrandtours.com

# Secret used to sign preview-link JWTs ("Copy preview link" in the editor topbar).
# Generate with `openssl rand -base64 32`. Rotate to invalidate all outstanding preview links.
PREVIEW_TOKEN_SECRET=

# ============================================================
# HubSpot (lead capture from the Enquire CTA)
# Portal ID is global; form IDs are per-brochure (configured in Sanity).
# ============================================================
HUBSPOT_PORTAL_ID=
# Optional: private app token if submitting via HubSpot API directly
HUBSPOT_PRIVATE_APP_TOKEN=

# ============================================================
# Resend (transactional email for new-lead notifications)
# ============================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@grandprixgrandtours.com
